{
  "name": "roleta",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p src/main/tsconfig.json",
    "package": "npm run build && electron-builder",
    "start": "electron .",
    "test": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "electron": "^28.2.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "vitest": "^1.3.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.lucky.spin",
    "productName": "Lucky Spin Roulette",
    "directories": {
      "output": "dist/installers"
    },
    "files": [
      "dist/main/**/*",
      "dist/renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
